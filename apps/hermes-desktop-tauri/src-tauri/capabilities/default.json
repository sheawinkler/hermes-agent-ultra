{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Shared Terra desktop/mobile capabilities: webview, events, paths, websocket",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:4173",
      "http://127.0.0.1:4173"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    "core:webview:allow-internal-toggle-devtools",
    "core:webview:allow-set-webview-zoom",
    "core:window:allow-start-dragging",
    "websocket:default"
  ]
}
