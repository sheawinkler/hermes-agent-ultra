{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "mobile",
  "description": "Mobile shell: restricted IPC set without PTY, native menu, or desktop window APIs",
  "windows": ["main"],
  "platforms": ["iOS", "android"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    "core:webview:allow-set-webview-zoom",
    "core:window:allow-start-dragging",
    "websocket:default"
  ]
}
