{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hermes Desktop Community",
  "version": "0.16.0",
  "identifier": "com.hermes.desktop.community",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hermes Desktop Community",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 18
        },
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* http://[::1]:* ws://127.0.0.1:* ws://localhost:* ws://[::1]:* https://* wss://*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' asset: http://asset.localhost blob: data:",
      "capabilities": [
        "default",
        "desktop"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "appimage",
      "deb",
      "nsis"
    ],
    "resources": [
      "../installers/windows/install-service.ps1",
      "../installers/windows/uninstall-service.ps1",
      "../installers/macos/app.terra.http.plist",
      "../installers/macos/postinstall.sh"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
